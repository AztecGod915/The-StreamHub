{
  "rewrites": [
    { "source": "/api/:path*", "destination": "/api/:path*" },
    { "source": "/:path*",     "destination": "/index.html" }
  ],
  "crons": [
    {
      "path": "/api/notify",
      "schedule": "0 14 * * 0"
    },
    {
      "path": "/api/game-alerts",
      "schedule": "0,30 * * * *"
    }
  ]
}
